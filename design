<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>東京大学ソーラーボートレーシング 新歓ビラ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans JP', sans-serif;
            background-color: #f3f4f6;
        }
        /* B4サイズの縦横比 (1 : 1.414) を維持するコンテナ */
        .b4-page {
            width: 100%;
            max-width: 800px;
            aspect-ratio: 1 / 1.414;
            background-color: white;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            margin: 0 auto;
            position: relative;
            overflow: hidden;
        }
        /* 印刷用の設定 */
        @media print {
            body { background-color: white; margin: 0; padding: 0; }
            .print-container { padding: 0 !important; gap: 0 !important; }
            .b4-page {
                box-shadow: none;
                margin: 0;
                width: 257mm;
                height: 364mm;
                max-width: none;
                aspect-ratio: auto;
                page-break-after: always;
            }
        }
        .clip-path-slant {
            clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
        }
        .text-shadow {
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
        /* 以下を追加：文字のフチドリや新しい装飾用 */
        .text-stroke {
            text-shadow: 
                -2px -2px 0 #333,
                 2px -2px 0 #333,
                -2px  2px 0 #333,
                 2px  2px 0 #333,
                 0px  4px 6px rgba(0,0,0,0.5);
        }
        .clip-path-banner {
            clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);
        }
        .wave-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='100' height='40' viewBox='0 0 100 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 20 Q 12.5 0, 25 20 T 50 20 T 75 20 T 100 20' fill='none' stroke='%238bb7d6' stroke-width='4' stroke-linecap='round'/%3E%3Cpath d='M0 30 Q 12.5 10, 25 30 T 50 30 T 75 30 T 100 30' fill='none' stroke='%238bb7d6' stroke-width='4' stroke-linecap='round'/%3E%3C/svg%3E");
            background-repeat: repeat-x;
        }
    </style>
</head>
<body class="py-8">

<div class="print-container flex flex-col gap-12 px-4">

    <!-- ==========================================
         表面 (Front)
         ========================================== -->
    <div class="b4-page flex flex-col relative bg-[#1b325f]">
        
        <!-- 背景画像エリア (上部 70%) -->
        <div class="absolute top-0 left-0 w-full h-[73%] bg-blue-300">
            <!-- 【変更点1】大きな背景写真 -->
            <img src="top1.jpg" class="absolute inset-0 w-full h-full object-cover">
            
            <!-- 上部の文字を見やすくするための薄いグラデーション -->
            <div class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-blue-900/60 to-transparent"></div>
            
            <!-- 太陽の装飾 (右上) -->
            <svg class="absolute -top-12 -right-12 w-64 h-64 text-[#f0a030] opacity-90 z-10" viewBox="0 0 100 100" fill="currentColor">
                <circle cx="80" cy="20" r="18" />
                <line x1="80" y1="42" x2="80" y2="55" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                <line x1="58" y1="20" x2="45" y2="20" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                <line x1="64" y1="36" x2="55" y2="45" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                <line x1="64" y1="4" x2="55" y2="-5" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                <line x1="96" y1="36" x2="105" y2="45" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            </svg>

            <!-- 波の装飾 -->
            <div class="absolute top-1/4 left-4 w-32 h-16 wave-pattern opacity-80 z-10"></div>
            <div class="absolute top-1/2 right-4 w-32 h-16 wave-pattern opacity-80 z-10"></div>

            <!-- ヘッダーテキスト -->
            <div class="absolute top-8 left-0 w-full text-center z-20 text-white">
                <h2 class="text-2xl font-black tracking-wider text-shadow">東京大学ソーラーボートレーシング</h2>
                <p class="text-sm font-bold tracking-widest mt-1 text-shadow">UNIVERSITY OF TOKYO SOLAR BOAT RACING</p>
                <div class="flex items-center justify-center mt-3 gap-3">
                    <div class="w-12 h-12 bg-white text-black rounded-full flex items-center justify-center text-2xl shadow-lg border-2 border-yellow-500">🦅</div>
                    <h1 class="text-5xl font-black tracking-widest text-[#f5d0a9] text-stroke">YATAGARASU</h1>
                    <div class="text-4xl text-shadow">☀️</div>
                </div>
            </div>

            <!-- メインキャッチコピー -->
            <div class="absolute top-[35%] left-0 w-full text-center z-20">
                <h2 class="text-4xl md:text-5xl font-black text-white text-stroke leading-tight tracking-tight">
                    水面を翔ける、未来を創る。<br>
                    次世代の船を、君の手で。
                </h2>
            </div>
            
            <!-- 実績バッジ -->
            <div class="absolute bottom-12 left-1/2 transform -translate-x-1/2 z-20 w-11/12 max-w-lg">
                <div class="bg-white/95 text-center py-2 px-4 rounded-xl border-4 border-[#1b325f] shadow-xl transform -rotate-1">
                    <p class="text-blue-900 font-bold text-sm">2025年度 ソーラー・人力ボートレース全日本選手権大会</p>
                    <p class="text-[#d97736] font-black text-xl mt-1">ソーラーAクラス 総合準優勝 ＆ 会長特別賞 受賞！</p>
                </div>
            </div>
        </div>

        <!-- 下部 募集エリア (紺色背景) -->
        <div class="absolute bottom-0 left-0 w-full h-[32%] z-30">
            
            <!-- 白い斜めの帯「新入部員募集」 -->
            <div class="absolute -top-12 right-0 w-[85%] h-24 bg-white clip-path-banner flex items-center justify-center pl-10 shadow-lg">
                <div class="text-center">
                    <h2 class="text-[#d97736] text-4xl font-black tracking-widest">新入部員募集</h2>
                    <p class="text-[#1b325f] font-bold tracking-widest text-sm mt-1">RECRUITING NEW MEMBERS</p>
                </div>
            </div>

            <div class="w-full h-full flex pt-14 pb-6 px-8 relative">
                <!-- 波の装飾 -->
                <div class="absolute bottom-4 left-4 w-24 h-16 wave-pattern opacity-50"></div>
                
                <!-- 左側：丸い写真 -->
                <div class="w-2/5 flex items-center justify-center relative z-10 pl-2">
                    <div class="w-56 h-56 rounded-full border-8 border-[#1b325f] outline outline-4 outline-white overflow-hidden bg-gray-300 flex items-center justify-center shadow-2xl relative">
                        <!-- 【変更点2】丸く切り抜かれた活動写真 -->
                        <img src="活動写真.jpg" alt="活動風景" class="w-full h-full object-cover">
                    </div>
                    <!-- アクセントの装飾線 -->
                    <svg class="absolute top-2 left-6 w-16 h-16 text-[#f0a030]" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round">
                        <line x1="20" y1="80" x2="10" y2="40" />
                        <line x1="40" y1="90" x2="25" y2="20" />
                        <line x1="60" y1="95" x2="50" y2="10" />
                    </svg>
                </div>

                <!-- 右側：ターゲットリスト -->
                <div class="w-3/5 pl-8 flex flex-col justify-center text-white z-10 relative">
                    <!-- こんな東大生におすすめ！ -->
                    <div class="bg-[#d97736] text-white font-bold px-4 py-1 rounded-full inline-block mb-3 self-start shadow-md text-sm">
                        こんな東大生におすすめ！
                    </div>
                    
                    <ul class="space-y-1.5 text-lg font-bold">
                        <li class="flex items-center"><span class="text-[#f0a030] mr-2 text-xl">⚙️</span>ものづくりが好き</li>
                        <li class="flex items-center"><span class="text-[#f0a030] mr-2 text-xl">🚀</span>航空／船舶／機械に興味がある</li>
                        <li class="flex items-center"><span class="text-[#f0a030] mr-2 text-xl">💻</span>AIやシミュレーションに関わりたい</li>
                        <li class="flex items-center"><span class="text-[#f0a030] mr-2 text-xl">🤝</span>チームで大きなプロジェクトをやりたい</li>
                    </ul>
                    
                    <div class="mt-4 border-t-2 border-[#f0a030] border-dashed pt-3">
                        <p class="text-center font-bold text-[#f5d0a9] leading-snug">
                            部員数7名（東大生100%）。経験・文理不問。<br>
                            必要なのは<span class="text-yellow-300 text-xl border-b-2 border-yellow-300 ml-1">「圧倒的な熱量」</span>です。
                        </p>
                    </div>

                    <!-- QRコードダミー -->
                    <div class="absolute bottom-0 right-0 w-20 h-20 bg-white p-1 rounded shadow flex items-center justify-center text-center">
                        <span class="text-xs text-black font-bold">QRコード</span>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- ==========================================
         裏面 (Back)
         ========================================== -->
    <div class="b4-page flex flex-col p-10">
        
        <!-- ヘッダー -->
        <div class="flex justify-between items-end border-b-2 border-gray-300 pb-4 mb-8">
            <h2 class="text-4xl font-black text-blue-900">PROJECT & VISION</h2>
            <p class="text-lg font-bold text-gray-500">東京大学ソーラーボートレーシング</p>
        </div>

        <!-- 目標セクション -->
        <div class="flex flex-col gap-6 mb-10">
            <!-- 2026年度の目標 -->
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 relative">
                <div class="absolute -left-3 -top-3 bg-blue-600 text-white font-bold px-4 py-1 rounded shadow">短期目標 (2026年度)</div>
                <h3 class="text-2xl font-black text-blue-900 mt-2 mb-3">「翼走」の実現</h3>
                <p class="text-gray-700 font-bold mb-4">船体が水面から浮いた状態で高速航行する「翼走（フォイリング）」を目指します。</p>
                <div class="flex flex-wrap gap-2">
                    <span class="bg-white border border-blue-300 text-blue-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">プロペラ製作</span>
                    <span class="bg-white border border-blue-300 text-blue-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">水中翼の改良</span>
                    <span class="bg-white border border-blue-300 text-blue-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">推進系の再設計（船外機製作）</span>
                </div>
            </div>

            <!-- 長期目標 -->
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-6 relative">
                <div class="absolute -left-3 -top-3 bg-orange-500 text-white font-bold px-4 py-1 rounded shadow">長期目標</div>
                <h3 class="text-2xl font-black text-orange-900 mt-2 mb-3">完全自律操船 ＆ モナコへの挑戦</h3>
                <p class="text-gray-700 font-bold mb-4">AIによる自律操船システムを構築し、世界最高峰の環境配慮型ボートレース「Monaco Energy Boat Challenge」に出場します。</p>
                <div class="flex flex-wrap gap-2">
                    <span class="bg-white border border-orange-300 text-orange-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">操縦系の電気制御</span>
                    <span class="bg-white border border-orange-300 text-orange-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">AI・機械学習</span>
                    <span class="bg-white border border-orange-300 text-orange-800 px-3 py-1 rounded-full text-sm font-bold shadow-sm">クリーンエネルギー</span>
                </div>
            </div>
        </div>

        <!-- キーワード＆技術スタック -->
        <div class="mb-10">
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <span class="w-1 h-6 bg-blue-600 inline-block mr-2"></span>
                私たちが触れる技術・分野
            </h3>
            <div class="flex flex-wrap gap-2">
                <!-- ハード・設計系 -->
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">ボート・造船</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">航空工学</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">工作機械・CAD</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">CFD (流体解析)</span>
                <!-- ソフト・システム系 -->
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">MBSE/MBD開発</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">シミュレーション</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">デジタルツイン</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">AI・センサ・制御</span>
                <!-- マネジメント・その他 -->
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">海運・物流</span>
                <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm font-bold">プロジェクトマネジメント</span>
            </div>
        </div>

        <div class="flex gap-6 mt-auto">
            <!-- 活動情報 -->
            <div class="w-2/3">
                <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                    <span class="w-1 h-6 bg-blue-600 inline-block mr-2"></span>
                    活動インフォメーション
                </h3>
                <table class="w-full text-left border-collapse">
                    <tbody>
                        <tr class="border-b border-gray-200">
                            <th class="py-3 pr-4 font-bold text-gray-600 w-28 align-top">活動頻度</th>
                            <td class="py-3 font-bold text-gray-800">
                                週1回MTG（1時間程度、メンバーで日程調整）<br>
                                <span class="text-sm text-gray-500">※実際の開発作業は内容・時期・個人の熱量に応じて柔軟に活動しています。</span>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-200">
                            <th class="py-3 pr-4 font-bold text-gray-600 align-top">活動場所</th>
                            <td class="py-3 font-bold text-gray-800">東京大学 船型試験水槽（本郷キャンパス）</td>
                        </tr>
                        <tr class="border-b border-gray-200">
                            <th class="py-3 pr-4 font-bold text-gray-600 align-top">メンバー構成</th>
                            <td class="py-3 font-bold text-gray-800">7名（東大生のみ）</td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="mt-6 flex items-center bg-gray-50 p-4 rounded-lg">
                    <div class="w-20 h-20 bg-gray-200 flex-shrink-0 flex items-center justify-center mr-4">
                        <span class="text-xs text-gray-500 text-center">QRコード<br>ダミー</span>
                    </div>
                    <div>
                        <p class="font-bold text-blue-900 mb-1">入部希望・見学・お問い合わせはこちら！</p>
                        <p class="text-sm text-gray-600">公式LINEやTwitter(X)のDMからお気軽にご連絡ください。<br>水槽見学も随時受け付けています。</p>
                    </div>
                </div>
            </div>

            <!-- 集合写真エリア -->
            <div class="w-1/3 flex flex-col items-center justify-center">
                <div class="w-full aspect-square bg-gray-300 rounded-lg overflow-hidden flex items-center justify-center border-4 border-white shadow-md">
                    <!-- 【変更点3】集合写真 -->
                    <img src="highlight1.jpg" class="w-full h-full object-cover">
                </div>
                <p class="text-xs text-gray-500 mt-2 font-bold">最高の環境で、共に挑もう。</p>
            </div>
        </div>

    </div>

</div>

</body>
</html>
